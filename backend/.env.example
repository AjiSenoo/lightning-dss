# Copy to .env and fill in values for your environment.
# Without DATABASE_URL the backend falls back to SQLite (fine for quick dev).

# PostgreSQL connection (matches docker-compose defaults)
DATABASE_URL=postgres://lightning:lightning@localhost:5432/lightning_dss

# Django secret key — change in production
SECRET_KEY=django-insecure-change-me-in-production

# Set to False in production
DEBUG=True

# JWT token lifetimes (optional — defaults shown)
# ACCESS_TOKEN_LIFETIME_HOURS=8
# REFRESH_TOKEN_LIFETIME_DAYS=7

# Inspection edit grace window in minutes (default 5)
# INSPECTION_EDIT_GRACE_MINUTES=5

# AHI weights — must sum to 1.0 (defaults shown)
# W_CUMULATIVE_STRESS=0.50
# W_PHYSICAL_CONDITION=0.30
# W_CALENDAR_AGE=0.20
