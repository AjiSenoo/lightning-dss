# Copy to .env and fill in. Used by docker-compose.prod.yml (compose interpolation)
# and injected into the Django container (env_file). Keep .env out of git.

# ---- Django ----
DEBUG=False
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_to_a_long_random_value
# Bare host(s) the browser uses to reach the app — your VPS IP (no port). Comma-separated.
ALLOWED_HOSTS=123.45.67.89

# ---- Plain-HTTP-on-IP mode (no domain / no TLS yet) ----
# With no TLS you MUST relax these, or admin login and HTTPS redirects break.
# When you later add a domain + certbot, remove/flip these back to True.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
# Needed for Django admin POST/login over the IP origin (include the published port):
CSRF_TRUSTED_ORIGINS=http://123.45.67.89:8080

# ---- Postgres ----
POSTGRES_DB=lightning_dss
POSTGRES_USER=lightning
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---- Runtime ----
# Host port nginx publishes. Pick something free (avoid your LLM agent's ports).
HTTP_PORT=8080
# gunicorn workers. Each loads numpy/scipy (~250MB). 2 is a safe start on a shared box.
GUNICORN_WORKERS=2
# Set to 1 for the FIRST boot only to load demo data, then back to 0.
SEED_DEMO=0
# Process/log timezone. WIB = Asia/Jakarta. Controls Django + gunicorn log timestamps.
TZ=Asia/Jakarta
