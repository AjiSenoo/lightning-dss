# Copy to .env and fill in. Used by docker-compose.prod.yml (compose interpolation)
# and injected into the Django container (env_file). Keep .env out of git.

# ---- Django ----
DEBUG=False
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_to_a_long_random_value
# Bare host(s) the browser uses to reach the app. Include the public hostname
# (nip.io or your domain) AND the raw IP. Comma-separated, no scheme/port.
ALLOWED_HOSTS=123-45-67-89.nip.io,123.45.67.89

# ---- HTTPS mode (Caddy terminates TLS on :443 via Let's Encrypt) ----
# Public hostname Caddy obtains a cert for. A nip.io wildcard resolves to your
# IP with no domain purchase: <dash-separated-ip>.nip.io. Or use a real domain.
SITE_ADDRESS=123-45-67-89.nip.io
# Caddy already forces http->https, so keep Django's own redirect off (avoids a
# proxy redirect-loop). Cookies are Secure and HSTS is emitted because nginx
# forwards X-Forwarded-Proto: https (see frontend/nginx.conf + NUM_PROXIES).
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CSRF_TRUSTED_ORIGINS=https://123-45-67-89.nip.io
# --- Plain-HTTP fallback (only if you deliberately skip TLS) ---
# SESSION_COOKIE_SECURE=False / CSRF_COOKIE_SECURE=False and
# CSRF_TRUSTED_ORIGINS=http://<ip>:8080, and re-publish nginx's :8080 port.

# ---- Postgres ----
POSTGRES_DB=lightning_dss
POSTGRES_USER=lightning
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---- Runtime ----
# Login brute-force guard (DRF ScopedRateThrottle) + proxy depth so it keys on
# the real client IP through Caddy -> nginx (2 hops). Leave NUM_PROXIES=2.
LOGIN_THROTTLE_RATE=10/min
NUM_PROXIES=2
# HTTP_PORT is unused in HTTPS mode (nginx is internal-only; Caddy owns 80/443).
# Only set it if you re-enable the plain-HTTP :8080 fallback on nginx.
# HTTP_PORT=8080
# gunicorn workers. Each loads numpy/scipy (~250MB). 2 is a safe start on a shared box.
GUNICORN_WORKERS=2
# Set to 1 for the FIRST boot only to load demo data, then back to 0.
SEED_DEMO=0
# Process/log timezone. WIB = Asia/Jakarta. Controls Django + gunicorn log timestamps.
TZ=Asia/Jakarta
